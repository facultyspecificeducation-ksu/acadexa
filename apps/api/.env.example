# Backend environment variables (copy to .env for local development)
# Supabase / Postgres connection
DATABASE_URL=postgresql://acadexa:acadexa@localhost:5432/acadexa
# Session/JWT secret for login-only authentication
SECRET_KEY=change-me
# AI provider configuration (used only by app/ai/client.py)
AI_PROVIDER=anthropic
AI_API_KEY=change-me
# CORS origins allowed to call this API (apps/web dev server, apps/desktop)
CORS_ORIGINS=http://localhost:5173

