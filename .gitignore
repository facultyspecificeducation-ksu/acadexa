# ============================================
# Acadexa - Clean Production .gitignore
# ============================================

# Dependencies
node_modules/
**/node_modules/
.pnpm-store/
.npm/

# Python
__pycache__/
*.py[cod]
*.so
.Python
.venv/
venv/
ENV/
env/
*.egg-info/
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
apps/api/__pycache__/
apps/api/.pytest_cache/
apps/api/.coverage

# Build outputs
dist/
build/
out/
release/
*.exe
*.dmg
*.AppImage

# Electron
apps/desktop/dist/
apps/desktop/build/
apps/desktop/out/

# Environment & Secrets
.env
.env.*
!.env.example
!.env.production.example
*.pem
*.key
*.crt
.secrets/
credentials.json

# Supabase
.supabase/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/
apps/**/logs/

# OS
.DS_Store
.Trashes
ehthumbs.db

# Temporary
*.tmp
.cache/
tmp/
temp/

# Testing
coverage/
.nyc_output/
playwright-report/
test-results/

# TypeScript
*.tsbuildinfo

# Vite
.vite/

# Turbo / Monorepo
.turbo/
nx/

# Docker
docker-compose.override.yml
**/docker-volumes/

# SQLite / DB
*.db
*.sqlite
*.sqlite3

# Backup
*.bak
*.old

# Certificates
*.p12
*.pfx

# Excel uploads only (runtime data)
apps/api/uploads/*.xlsx
apps/api/uploads/*.xls

# GitHub workflows (keep)
!.github/workflows/