erDiagram
    %% =========================================================
    %% Acadexa — Full ERD (25 tables) — generated from migrations 003/004
    %% =========================================================

    %% ---------- Authentication / Platform ----------
    PROFILES {
        uuid id PK "FK -> auth.users.id"
        text full_name
        text email
        text phone
        text avatar_url
        boolean is_active
        timestamptz created_at
        timestamptz updated_at
    }
    ROLES {
        uuid id PK
        text code
        text name_ar
        text name_en
        text description
    }
    USER_ROLES {
        uuid id PK
        uuid user_id FK
        uuid role_id FK
        timestamptz created_at
    }

    %% ---------- Academic Structure ----------
    DEPARTMENTS {
        uuid id PK
        text code
        text name_ar
        text name_en
        text short_name
        boolean is_active
        timestamptz created_at
        timestamptz updated_at
    }

    %% ---------- Curriculum Management ----------
    CURRICULA {
        uuid id PK
        uuid department_id FK
        int regulation_year
        text name_ar
        int total_required_hours
        numeric min_gpa_to_graduate
        boolean is_active
        timestamptz created_at
        timestamptz updated_at
    }
    CURRICULUM_COURSES {
        uuid id PK
        uuid curriculum_id FK
        text course_code
        text name_ar
        text name_en
        int credit_hours
        int level
        term_enum term
        course_category_enum category
        boolean is_field_training
        boolean is_graduation_project
        boolean is_community_issues_course
        boolean is_active
    }
    COURSE_PREREQUISITES {
        uuid id PK
        uuid course_id FK
        uuid required_course_id FK
        text minimum_grade FK
    }
    ELECTIVE_GROUPS {
        uuid id PK
        uuid curriculum_id FK
        text name
        course_category_enum category
        int required_hours
        int min_courses
    }
    ELECTIVE_GROUP_COURSES {
        uuid group_id PK_FK
        uuid course_id PK_FK
    }
    GRADUATION_REQUIREMENTS {
        uuid id PK
        uuid curriculum_id FK
        int required_hours
        numeric min_gpa
        boolean requires_field_training
        int_array field_training_levels
        boolean requires_community_course
        text community_course_name_ar
        int max_study_years
    }
    ACADEMIC_RULES {
        uuid id PK
        uuid curriculum_id FK
        numeric probation_min_gpa
        int max_hours_regular_term
        int min_hours_regular_term
        int max_hours_summer
        int level_2_min_hours
        int level_3_min_hours
        int level_4_min_hours
        jsonb extra_rules
    }
    GRADE_SCALE {
        text grade_letter PK
        text name_ar
        numeric points
        numeric min_score
        numeric max_score
        boolean affects_gpa
        boolean is_passing
        text description
    }

    %% ---------- Excel Import Pipeline ----------
    IMPORT_JOBS {
        uuid id PK
        uuid uploaded_by FK
        uuid department_id FK
        text file_name
        text file_url
        import_status_enum status
        int total_students
        int successful_records
        int failed_records
        jsonb error_log
        timestamptz created_at
        timestamptz completed_at
    }
    IMPORTED_FILES {
        uuid id PK
        uuid import_job_id FK
        text original_name
        text storage_path
        text hash
        timestamptz created_at
    }
    RAW_STUDENTS {
        uuid id PK
        uuid import_job_id FK
        uuid student_id FK
        text sheet_name
        jsonb raw_data
        boolean parsed
        text parse_error
        timestamptz created_at
    }
    RAW_COURSES {
        uuid id PK
        uuid raw_student_id FK
        text semester_raw
        jsonb course_raw_data
        timestamptz created_at
    }

    %% ---------- Student Records ----------
    STUDENTS {
        uuid id PK
        text student_code "UNIQUE"
        text name
        uuid department_id FK
        uuid curriculum_id FK
        int enrollment_year
        int current_level
        numeric cumulative_gpa
        numeric cumulative_percentage
        int attempted_hours
        int completed_hours
        numeric completion_rate
        int total_passed_courses
        int total_failed_courses
        boolean is_active
        uuid last_import_job_id FK
        timestamptz created_at
        timestamptz updated_at
    }
    STUDENT_SEMESTERS {
        uuid id PK
        uuid student_id FK
        int semester_number
        text academic_year
        text level_semester_raw
        term_enum term
        int level
        numeric gpa
        int attempted_hours
        int completed_hours
        int passed_courses
        int failed_courses
        int total_courses
        numeric quality_points
    }
    STUDENT_COURSES {
        uuid id PK
        uuid student_id FK
        uuid semester_id FK
        uuid curriculum_course_id FK
        text course_code
        text course_name
        int credit_hours
        text grade_letter FK
        text grade_letter_raw
        numeric grade_points
        numeric grade_score
        boolean passed
        text passed_raw
        int attempt_number
        boolean is_latest_attempt
        timestamptz updated_at
    }

    %% ---------- Advisory ----------
    ADVISOR_ASSIGNMENTS {
        uuid id PK
        uuid advisor_id FK
        uuid student_id FK
        timestamptz assigned_at
        boolean is_active
    }
    ADVISOR_NOTES {
        uuid id PK
        uuid student_id FK
        uuid advisor_id FK
        text note
        timestamptz created_at
        timestamptz updated_at
    }

    %% ---------- Expert System ----------
    ACADEMIC_ANALYSES {
        uuid id PK
        uuid student_id FK
        academic_status_enum academic_status
        risk_level_enum risk_level
        boolean graduation_eligible
        timestamptz analyzed_at
    }
    ANALYSIS_ISSUES {
        uuid id PK
        uuid analysis_id FK
        text rule_code
        issue_severity_enum severity
        text title_ar
        text description_ar
        text recommendation_ar
        boolean resolved
        timestamptz created_at
    }

    %% ---------- Reporting ----------
    REPORTS {
        uuid id PK
        uuid student_id FK
        uuid department_id FK
        text report_type
        uuid generated_by FK
        jsonb data
        timestamptz created_at
    }
    DEPARTMENT_STATISTICS {
        uuid id PK
        uuid department_id FK
        timestamptz calculated_at
        int total_students
        numeric average_gpa
        numeric graduation_rate
        int risk_students_count
    }

    %% =========================================================
    %% Relationships (cardinalities)
    %% =========================================================

    %% Authentication
    PROFILES        ||--o{ USER_ROLES            : "1 profile -- N role grants"
    ROLES           ||--o{ USER_ROLES            : "1 role -- N grants"

    %% Academic structure / curriculum
    DEPARTMENTS     ||--o{ CURRICULA             : "1 department -- N curricula (per regulation year)"
    CURRICULA       ||--o{ CURRICULUM_COURSES    : "1 curriculum -- N courses"
    CURRICULA       ||--|| GRADUATION_REQUIREMENTS : "1 curriculum -- 1 requirements row"
    CURRICULA       ||--|| ACADEMIC_RULES        : "1 curriculum -- 1 rules row"
    CURRICULA       ||--o{ ELECTIVE_GROUPS       : "1 curriculum -- N elective groups"
    ELECTIVE_GROUPS ||--o{ ELECTIVE_GROUP_COURSES : "1 group -- N member courses"
    CURRICULUM_COURSES ||--o{ ELECTIVE_GROUP_COURSES : "1 course -- N group memberships"
    CURRICULUM_COURSES ||--o{ COURSE_PREREQUISITES : "1 course -- N prerequisite rows (course_id)"
    CURRICULUM_COURSES ||--o{ COURSE_PREREQUISITES : "1 course -- N prerequisite rows (required_course_id)"
    GRADE_SCALE     ||--o{ COURSE_PREREQUISITES  : "1 grade -- N min-grade prerequisites"

    %% Import pipeline
    PROFILES        ||--o{ IMPORT_JOBS           : "1 uploader -- N import jobs"
    DEPARTMENTS     ||--o{ IMPORT_JOBS           : "1 department -- N import jobs"
    IMPORT_JOBS     ||--o{ IMPORTED_FILES        : "1 job -- N files"
    IMPORT_JOBS     ||--o{ RAW_STUDENTS          : "1 job -- N raw student sheets"
    RAW_STUDENTS    ||--o{ RAW_COURSES           : "1 raw student -- N raw course rows"
    IMPORT_JOBS     ||--o{ STUDENTS              : "1 job -- N students last touched"

    %% Students
    DEPARTMENTS     ||--o{ STUDENTS              : "1 department -- N students"
    CURRICULA       ||--o{ STUDENTS              : "1 curriculum -- N students"
    STUDENTS        ||--o| RAW_STUDENTS          : "1 student -- 0..N matched raw sheets"
    STUDENTS        ||--o{ STUDENT_SEMESTERS     : "1 student -- N semesters"
    STUDENT_SEMESTERS ||--o{ STUDENT_COURSES     : "1 semester -- N course records"
    CURRICULUM_COURSES ||--o{ STUDENT_COURSES    : "1 curriculum course -- N student attempts"
    GRADE_SCALE     ||--o{ STUDENT_COURSES       : "1 grade letter -- N course records"

    %% Advisory
    PROFILES        ||--o{ ADVISOR_ASSIGNMENTS   : "1 advisor -- N assignments"
    STUDENTS        ||--o{ ADVISOR_ASSIGNMENTS   : "1 student -- N assignment records (history)"
    STUDENTS        ||--o{ ADVISOR_NOTES         : "1 student -- N notes"
    PROFILES        ||--o{ ADVISOR_NOTES         : "1 advisor -- N notes written"

    %% Expert system
    STUDENTS        ||--o{ ACADEMIC_ANALYSES     : "1 student -- N analysis runs"
    ACADEMIC_ANALYSES ||--o{ ANALYSIS_ISSUES     : "1 analysis -- N issues"

    %% Reports
    STUDENTS        ||--o{ REPORTS               : "1 student -- N reports"
    DEPARTMENTS     ||--o{ REPORTS               : "1 department -- N reports"
    PROFILES        ||--o{ REPORTS               : "1 generator -- N reports"
    DEPARTMENTS     ||--o{ DEPARTMENT_STATISTICS : "1 department -- N snapshots"